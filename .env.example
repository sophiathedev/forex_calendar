# Token bot Discord (bắt buộc)
DISCORD_TOKEN=

# ID guild để đăng ký slash command (bắt buộc)
GUILD_ID=

# ID channel để bot tự đăng tin (bắt buộc)
CHANNEL_ID=

# URL service FlareSolverr giải Cloudflare.
# Khi chạy bằng docker-compose, dùng http://flaresolverr:8191
# Khi chạy local (go run), dùng http://localhost:8191
FLARESOLVERR_URL=http://localhost:8191
